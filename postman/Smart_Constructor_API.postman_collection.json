{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Smart Constructor API",
    "description": "Import this file into Postman. Collection variables: `host`, `baseUrl` (default http://localhost:8080/api/v1), `accessToken`, ids. After **Auth → Register**, set **otp_code** to the OTP from email, then run **Verify OTP** — accessToken saves automatically. Protected routes use Bearer `{{accessToken}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "host", "value": "http://localhost:8080" },
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "register_email", "value": "" },
    { "key": "otp_code", "value": "000000" },
    { "key": "vendor_id", "value": "" },
    { "key": "project_id", "value": "" },
    { "key": "material_id", "value": "" },
    { "key": "order_id", "value": "" },
    { "key": "worker_id", "value": "" },
    { "key": "payroll_id", "value": "" }
  ],
  "item": [
    {
      "name": "Root",
      "item": [
        {
          "name": "Welcome",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{host}}/",
            "description": "Public health / welcome endpoint."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const body = JSON.parse(pm.request.body.raw);",
                  "  if (body.email) pm.collectionVariables.set('register_email', body.email);",
                  "} catch (e) {}",
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama\": \"Postman Test User\",\n  \"email\": \"postman-test@example.com\",\n  \"gender\": \"male\",\n  \"phoneNumber\": \"+6281212345678\",\n  \"tanggalLahir\": \"1990-05-15\",\n  \"kategoriSpesialisasi\": \"Tukang Batu\",\n  \"password\": \"Postman1!\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Sends OTP to email. Copy OTP from email into collection variable **otp_code**, then call Verify OTP. `role` is optional (defaults to `pekerja`)."
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.access_token) {",
                  "  pm.collectionVariables.set('accessToken', json.data.access_token);",
                  "}",
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{register_email}}\",\n  \"otp\": \"{{otp_code}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-otp",
            "description": "Set **otp_code** in collection variables to the 6-digit code from email after Register."
          }
        },
        {
          "name": "Login (send OTP)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@proyek.in\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Sends login OTP to email. After receiving OTP, run Verify OTP to get accessToken."
          }
        }
      ]
    },
