# Copy to .env and adjust values.
# cp .env.example .env

# --- App ---
NODE_ENV=development
PORT=8080
API_VERSION=v1
# Host port when API runs in Docker (`make docker-dev-api-up`). Container listens on 8080.
# DEV_HOST_PORT=8080

# --- MongoDB (local: use docker-compose.dev or a local mongod) ---
MONGODB_URI=mongodb://127.0.0.1:27017/smart_constructor

# --- Redis (ioredis; Redis 6+ default user is "default") ---
# With docker-compose.dev, password matches the redis service (see README).
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=dev_redis_secret

# --- Auth ---
# Use a long random string in production.
JWT_SECRET=change_me_to_a_long_random_secret_in_production

# --- Email (OTP via Gmail; optional in dev if you do not hit send-otp) ---
EMAIL_USER=
EMAIL_PASSWORD=

# --- Site / attendance defaults (optional) ---
SITE_NAME=Klapa Village
SITE_LAT=-6.2615
SITE_LNG=106.9335
SITE_RADIUS_METERS=100
